import random
import string

def check_password(password):
    if len(password) < 8:
        return "Weak: Too short! Use at least 8 characters"
    elif not any(c in "ABCDEFGHIJKLMNOPQRSTUVWXYZ" for c in password):
        return "Weak: Add UPPERCASE letters (A-Z)"
    elif not any(c in "abcdefghijklmnopqrstuvwxyz" for c in password):
        return "Weak: Add lowercase letters (a-z)"
    elif not any(c in "0123456789" for c in password):
        return "Weak: Add numbers (0-9)"
    elif not any(c in "!@#$%&*" for c in password):
        return "Weak: Add symbols (!@#$%&*)"
    else:
        return "Strong:  Good password!"

def make_password():
    letters = "abcdefghijklmnopqrstuvwxyz"
    capital_letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    numbers = "0123456789"
    symbols = "!@#$%&*"
    
    # Pick one from each type
    pwd = [
        random.choice(letters),
        random.choice(capital_letters), 
        random.choice(numbers),
        random.choice(symbols) ]
    
    # then we ,Add 4 more random characters
    all_chars = letters + capital_letters + numbers + symbols
    for i in range(4):
        pwd.append(random.choice(all_chars))
    
    # Mixing them up
    random.shuffle(pwd)
    return ''.join(pwd)

